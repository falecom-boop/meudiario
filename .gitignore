*.apk

# Android build artifacts (keep the rest of android/ tracked)
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/capacitor-cordova-android-plugins/build/

# Editor/OS cruft
.DS_Store
Thumbs.db
