# Supabase environment variables for Vite
# Copy this file to .env or .env.local and replace with your Supabase project values.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: override table names if you use different names in Supabase.
VITE_SUPABASE_CURRENT_TABLE=diario_current
VITE_SUPABASE_SNAPSHOT_TABLE=diario_snapshots

# Admin password: only gates destructive in-app actions (e.g. deleting a
# class), unrelated to login (login is handled by Supabase Auth). Store only
# the SHA-256 hash, not the plain text. Generate the hash by opening
# supabase/gerar-hash-senha.html in a browser.
VITE_ADMIN_PASSWORD_HASH=
