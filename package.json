{
  "name": "checkout-turmas",
  "version": "1.2.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "desktop:dist": "npm run build && electron-builder --win nsis",
    "test:sync": "node scripts/sync-safety.test.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "build": {
    "appId": "br.capufrj.diariodeclasse",
    "productName": "Diário de Classe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Diário de Classe"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.110.7",
    "@vitejs/plugin-react": "^5.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
